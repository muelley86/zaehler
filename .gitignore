# --- Frontend-Build-Output ---
# Vite schreibt das gebaute Bundle nach backend/src/meters/static/.
# Source-of-truth ist frontend/. Auf Production-Hosts (LXC) wird beim
# Update neu gebaut; nichts hier wird per git übertragen.
backend/src/meters/static/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# Virtuelle Umgebungen
.venv/
venv/
env/

# --- Node / Frontend ---
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
coverage/

# --- App-Daten (SQLite) ---
data/*.db
data/*.db.*
data/*.db-journal
data/*.db-wal
data/*.db-shm
# DB-Dateien/-Backups generell (z. B. Produktions-Backups im Repo-Root) —
# echte Daten duerfen nie zu GitHub.
*.db
*.db.gz

# --- Sekrete & lokale Configs ---
.env
.env.*
!.env.example
*.local

# --- IDE & OS ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
.claude/
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
